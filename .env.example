# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key

# S3 Bucket for file storage
S3_BUCKET=psec-baseline-hunter-dev

# Application URL (for CORS and callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Set true only behind a trusted reverse proxy that sets client IP headers.
LLM_RATE_LIMIT_TRUST_PROXY=false

# Optional LLM providers. Leave keys unset to use rule-based summaries.
# Anthropic is selected first when ANTHROPIC_API_KEY is set.
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-3-5-sonnet-20241022
#
# OpenAI is selected only when Anthropic is not configured.
# Current implementation uses direct Chat Completions fetch, not Responses API or SDK.
# OPENAI_API_KEY=sk-your-key-here
# OPENAI_MODEL=gpt-4o

# LLM provider safety controls
LLM_REQUEST_TIMEOUT_MS=15000
LLM_MAX_TOKENS=2000
